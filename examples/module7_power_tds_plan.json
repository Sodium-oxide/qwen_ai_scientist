{
  "schema_version": "1.0",
  "experiment_id": "demo_power_tds_001",
  "hypothesis": {
    "id": "hyp_power_tds_001",
    "statement": "提高等效阻尼可增大故障临界清除时间并减小最大功角分离。"
  },
  "domain": "电力系统暂态稳定",
  "objective": "使用ANDES TDS扫描故障清除时间并估计CCT。",
  "task": {
    "type": "transient_tds"
  },
  "dataset": {
    "path": "",
    "fallback": "ieee9_reduced_dynamic"
  },
  "parameters": {
    "fault_bus": 5,
    "fault_time_seconds": 1.0,
    "simulation_end_seconds": 8.0,
    "proposed_damping": 0.12,
    "clearing_duration_grid": [0.05, 0.08, 0.1, 0.12, 0.15, 0.18, 0.22]
  },
  "baselines": [
    {
      "name": "base_damping",
      "description": "原始阻尼参数"
    }
  ],
  "metrics": [
    {
      "name": "cct_seconds",
      "direction": "maximize",
      "primary": true
    },
    {
      "name": "max_rotor_angle_deg",
      "direction": "minimize"
    },
    {
      "name": "voltage_nadir_pu",
      "direction": "maximize"
    }
  ],
  "execution": {
    "backend": "auto",
    "cpu_limit": 4,
    "memory_limit_mb": 8192,
    "timeout_seconds": 3600,
    "network_enabled": false
  },
  "generation": {
    "mode": "template"
  },
  "output": {
    "result_file": "exp_power_result.json"
  }
}
