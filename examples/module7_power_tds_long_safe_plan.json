{
  "schema_version": "1.0",
  "experiment_id": "demo_power_tds_long_safe_001",
  "hypothesis": {
    "id": "hyp_power_tds_long_safe_001",
    "statement": "A controlled longer ANDES TDS run can produce real transient-stability evidence under Module 7 sandbox limits."
  },
  "domain": "power_system",
  "objective": "Run a longer but bounded ANDES TDS case for Module 7 validation.",
  "task": {
    "type": "transient_tds"
  },
  "dataset": {
    "path": "D:/python/Lib/site-packages/andes/cases/5bus/pjm5bus.json",
    "fallback": "ieee9_reduced_dynamic"
  },
  "parameters": {
    "fault_bus": 3,
    "fault_time_seconds": 0.1,
    "simulation_end_seconds": 3.0,
    "max_tds_simulation_seconds": 3.0,
    "proposed_damping": 0.12,
    "clearing_duration_grid": [0.03]
  },
  "baselines": [
    {
      "name": "base_damping",
      "description": "Base damping setting."
    }
  ],
  "metrics": [
    {
      "name": "cct_seconds",
      "direction": "maximize",
      "primary": true
    },
    {
      "name": "max_rotor_angle_deg",
      "direction": "minimize"
    },
    {
      "name": "voltage_nadir_pu",
      "direction": "maximize"
    }
  ],
  "execution": {
    "backend": "local",
    "cpu_limit": 2,
    "memory_limit_mb": 4096,
    "timeout_seconds": 300,
    "network_enabled": false,
    "allow_real_tds": true,
    "allow_long_tds": false,
    "max_tds_simulation_seconds": 3.0,
    "max_repair_rounds": 0
  },
  "generation": {
    "mode": "template"
  },
  "output": {
    "result_file": "exp_power_tds_long_safe_result.json"
  }
}
